{
  "name": "electromagnetic-induction-courseware",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "vite --host 127.0.0.1",
    "dev:share": "vite --host 0.0.0.0",
    "preview": "vite preview",
    "preview:local": "vite preview --host 127.0.0.1",
    "preview:share": "vite preview --host 0.0.0.0",
    "links": "node --experimental-strip-types scripts/print-access-links.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build",
    "search:videos": "node --experimental-strip-types scripts/search-videos.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^27.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  }
}
